# Demo de /audit para o README — gera audit/demo.gif
# Reprodução encenada via demo/bin/claude (VHS grava um shell, não o REPL do Claude Code).
Output audit/demo.gif

Set Shell bash
Set FontSize 15
Set Width 1180
Set Height 660
Set Padding 26
Set TypingSpeed 55ms
Set Theme "Catppuccin Mocha"

Hide
Type 'export PATH="$PWD/demo/bin:$HOME/.local/bin:$PATH"; clear'
Enter
Show

Sleep 600ms
Type 'claude "/audit ~/dev/sistema_gado"'
Sleep 900ms
Enter
Sleep 10s
