# Demo de /brute-tester para o README — gera brute-tester/demo.gif
# Reprodução encenada via demo/bin/claude (VHS grava um shell, não o REPL do Claude Code).
Output brute-tester/demo.gif

Set Shell bash
Set FontSize 15
Set Width 1180
Set Height 540
Set Padding 26
Set TypingSpeed 55ms
Set Theme "Catppuccin Mocha"

Hide
Type 'export PATH="$PWD/demo/bin:$HOME/.local/bin:$PATH"; clear'
Enter
Show

Sleep 600ms
Type 'claude "/brute-tester http://localhost:5000/login --intensity light"'
Sleep 900ms
Enter
Sleep 8s
